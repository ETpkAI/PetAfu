# 复制此文件为 .env 并填写真实值
# === AI 大模型 ===
OPENAI_API_KEY=sk-xxxx
OPENAI_API_BASE=https://api.openai.com/v1  # 或 DeepSeek/智谱等国内代理
LLM_MODEL=gpt-4o                           # 或 deepseek-chat / glm-4v

# === 数据库 ===
DATABASE_URL=postgresql+asyncpg://petafu:petafu123@localhost:5432/petafu_db

# === ChromaDB (RAG向量库, 默认本地文件模式无需配置) ===
CHROMA_PERSIST_DIR=./chroma_db

# === 服务器 ===
SECRET_KEY=change-this-to-a-random-secret-key-64chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200   # 30天

# === 知识库路径 ===
KNOWLEDGE_BASE_DIR=../knowledge_base
